# ============================================================
# Stock Analysis Deep Agent - Environment Variables
# Copy this file to .env and fill in your actual values
# ============================================================

# ---- LLM Provider (choose one) ----
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---- Model Selection ----
# Orchestrator uses the full model; sub-agents use the lighter variant
AGENT_MODEL=openai:gpt-5.2
SUBAGENT_MODEL=openai:gpt-5.2

# ---- Tavily Web Search (for news analysis) ----
# Get your free key at https://app.tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ---- FRED API (for macroeconomic indicators: Fed rate, CPI, GDP, etc.) ----
# Get your FREE key at https://fred.stlouisfed.org/docs/api/api_key.html
# If not set, the agent uses yfinance as a fallback for Treasury yields
FRED_API_KEY=your_fred_api_key_here

# ---- Alpha Vantage (optional: for additional stock data via MCP) ----
# Get your free key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# ---- LangSmith Tracing (optional) ----
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=stock-analysis-deep-agent
